# ========== 阿里云百炼（DashScope OpenAI 兼容模式）==========
# 控制台：https://bailian.console.aliyun.com/ → 密钥管理 → 创建 API-KEY
OPENAI_API_KEY=sk-your-dashscope-api-key

# 百炼 OpenAI 兼容接口（固定值，一般无需修改）
OPENAI_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1

# 模型名称（在百炼控制台开通对应模型后使用）
# 常用：qwen-turbo（快/省）| qwen-plus（推荐）| qwen-max（最强）
OPENAI_MODEL=qwen-plus

# ========== 若改用 OpenAI 官方，可改为：==========
# OPENAI_BASE_URL=https://api.openai.com/v1
# OPENAI_MODEL=gpt-4o

# SQLite 数据库路径
DATABASE_URL=sqlite+aiosqlite:///./recruiter.db

# 聊天历史上下文条数限制
CHAT_HISTORY_LIMIT=10

# 复聊触发阈值（小时）
FOLLOW_UP_HOURS=24

# 定时扫描间隔（分钟）
SCHEDULER_INTERVAL_MINUTES=10

# Agent 模式（LangChain 工具调用 + 简历解析）
AGENT_MODE_ENABLED=true

# Webhook 鉴权密钥（对接 Boss/RPA 时使用，留空则不校验）
WEBHOOK_SECRET=

# 简历上传目录与大小限制（MB）
RESUME_UPLOAD_DIR=./uploads/resumes
MAX_RESUME_SIZE_MB=10
